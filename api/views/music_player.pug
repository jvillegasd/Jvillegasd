svg(width = "460" height = "240" fill="none" xmlns = "http://www.w3.org/2000/svg")
  foreignObject(x = "0" y = "0" width = "460" height = "240")
    div(xmlns = "http://www.w3.org/1999/xhtml")
      style.

        #player {
          width: 460px;
          height: 240px;
          position: relative;
          font-family: Georgia, "Times New Roman", serif;
        }

        #plinth {
          position: absolute;
          top: 6px;
          left: 8px;
          width: 444px;
          height: 228px;
          border-radius: 14px;
          background:
            repeating-linear-gradient(
              94deg,
              rgba(0,0,0,0.10) 0 1px,
              rgba(255,220,160,0.04) 1px 3px,
              rgba(0,0,0,0.14) 3px 4px,
              transparent 4px 11px),
            linear-gradient(162deg, #6b3f20 0%, #432312 55%, #2a170a 100%);
          box-shadow:
            0 14px 22px rgba(0,0,0,0.5),
            inset 0 2px 3px rgba(255,200,140,0.18),
            inset 0 -3px 6px rgba(0,0,0,0.55),
            inset 0 0 0 2px rgba(201,169,97,0.35);
        }

        #platter_mat {
          position: absolute;
          top: 24px;
          left: 24px;
          width: 180px;
          height: 180px;
          border-radius: 50%;
          background: radial-gradient(circle at center, #1a0f08 0%, #0a0604 100%);
          box-shadow:
            0 8px 14px rgba(0,0,0,0.6),
            inset 0 0 0 2px #c9a961,
            inset 0 0 0 3px rgba(0,0,0,0.35),
            inset 0 0 0 8px rgba(201,169,97,0.35),
            inset 0 0 10px rgba(0,0,0,0.6);
        }

        #vinyl {
          position: absolute;
          top: 12px;
          left: 12px;
          width: 156px;
          height: 156px;
          border-radius: 50%;
          background:
            repeating-radial-gradient(circle at center,
              rgba(255,255,255,0.05) 0 1px,
              rgba(0,0,0,0) 1px 2px,
              rgba(255,255,255,0.02) 2px 3px,
              rgba(0,0,0,0) 3px 4px),
            radial-gradient(circle at center, #0a0a0a 0%, #000 100%);
          animation: spin 3.2s linear infinite;
          transform-origin: center center;
          box-shadow: 0 0 0 1px rgba(255,255,255,0.06);
        }

        #label {
          position: absolute;
          top: 50%;
          left: 50%;
          width: 68px;
          height: 68px;
          margin: -34px 0 0 -34px;
          border-radius: 50%;
          overflow: hidden;
          box-shadow:
            0 0 0 2px #c9a961,
            0 0 0 3px rgba(0,0,0,0.45),
            0 0 0 5px rgba(201,169,97,0.25);
        }

        #album_art {
          width: 100%;
          height: 100%;
          background-size: cover;
          background-position: center;
        }

        #spindle {
          position: absolute;
          top: 50%;
          left: 50%;
          width: 7px;
          height: 7px;
          margin: -3.5px 0 0 -3.5px;
          border-radius: 50%;
          background: radial-gradient(circle at 30% 30%, #fff2c6 0%, #c9a961 55%, #6b5a30 100%);
          box-shadow: 0 1px 2px rgba(0,0,0,0.6);
          z-index: 3;
        }

        #tonearm_arm {
          position: absolute;
          top: 33px;
          left: 192px;
          width: 3px;
          height: 80px;
          background: linear-gradient(90deg, #5e5e5e 0%, #dedede 30%, #f4f4f4 50%, #b0b0b0 80%, #4f4f4f 100%);
          border-radius: 2px;
          transform-origin: top center;
          transform: rotate(22deg);
          box-shadow: 1px 2px 2px rgba(0,0,0,0.35);
          z-index: 4;
        }

        #counterweight {
          position: absolute;
          top: -11px;
          left: -7px;
          width: 17px;
          height: 13px;
          border-radius: 4px;
          background: radial-gradient(ellipse at 30% 35%, #d9b96d 0%, #8b7335 55%, #4d3f1e 100%);
          box-shadow: 0 2px 3px rgba(0,0,0,0.45), inset 0 1px 1px rgba(255,230,180,0.4);
        }

        #headshell {
          position: absolute;
          bottom: -8px;
          left: -7px;
          width: 17px;
          height: 10px;
          background: linear-gradient(180deg, #2b2b2b 0%, #0d0d0d 100%);
          border-radius: 2px;
          transform-origin: top right;
          transform: rotate(-22deg);
          box-shadow: 0 2px 3px rgba(0,0,0,0.55);
        }

        #cartridge {
          position: absolute;
          bottom: -6px;
          left: 3px;
          width: 0;
          height: 0;
          border-left: 2.5px solid transparent;
          border-right: 2.5px solid transparent;
          border-top: 7px solid #d9d9d9;
        }

        #tonearm_pivot {
          position: absolute;
          top: 20px;
          left: 180px;
          width: 26px;
          height: 26px;
          border-radius: 50%;
          background: radial-gradient(circle at 32% 32%, #f5e6b3 0%, #c9a961 45%, #7a5d22 100%);
          box-shadow:
            0 3px 5px rgba(0,0,0,0.5),
            inset 0 -2px 3px rgba(0,0,0,0.4),
            inset 0 1px 2px rgba(255,240,200,0.5);
          z-index: 5;
        }

        #tonearm_pivot::after {
          content: "";
          position: absolute;
          top: 8px;
          left: 8px;
          width: 10px;
          height: 10px;
          border-radius: 50%;
          background: radial-gradient(circle at 35% 35%, #fffbe8 0%, #b8933a 65%, #3d2d0f 100%);
          box-shadow: inset 0 1px 1px rgba(0,0,0,0.4);
        }

        .paused #vinyl {
          animation-play-state: paused;
        }

        .paused #tonearm_arm {
          transform: rotate(-6deg);
        }

        #info {
          position: absolute;
          top: 38px;
          left: 222px;
          right: 22px;
        }

        #title_wrap,
        #artist_wrap {
          overflow: hidden;
          width: 100%;
        }

        #artist_wrap {
          margin-top: 6px;
        }

        #song_name,
        #artist_name {
          display: block;
          white-space: nowrap;
          overflow: hidden;
          text-overflow: ellipsis;
          margin: 0;
        }

        #song_name {
          font-size: 22px;
          color: #f5e6d3;
          font-weight: 600;
          letter-spacing: 0.5px;
          text-shadow: 0 1px 2px rgba(0,0,0,0.7);
        }

        #artist_name {
          font-size: 14px;
          color: #c9a961;
          font-style: italic;
          font-weight: normal;
          letter-spacing: 0.8px;
          text-shadow: 0 1px 2px rgba(0,0,0,0.6);
        }

        #title_wrap.marquee #song_name,
        #artist_wrap.marquee #artist_name {
          display: inline-block;
          width: auto;
          padding-right: 28px;
          overflow: visible;
          text-overflow: clip;
        }

        #title_wrap.marquee #song_name {
          animation: marquee_title 24s ease-in-out infinite;
        }

        #artist_wrap.marquee #artist_name {
          animation: marquee_artist 24s ease-in-out infinite;
        }

        @keyframes marquee_title {
          0%   { transform: translateX(0); }
          25%  { transform: translateX(calc(-100% + 216px)); }
          27%  { transform: translateX(calc(-100% + 216px)); }
          31%  { transform: translateX(0); }
          100% { transform: translateX(0); }
        }

        @keyframes marquee_artist {
          0%   { transform: translateX(0); }
          33%  { transform: translateX(0); }
          58%  { transform: translateX(calc(-100% + 216px)); }
          60%  { transform: translateX(calc(-100% + 216px)); }
          64%  { transform: translateX(0); }
          100% { transform: translateX(0); }
        }

        #progress_wrap {
          position: absolute;
          bottom: 30px;
          left: 222px;
          right: 22px;
        }

        #progress_base {
          height: 3px;
          background: rgba(0,0,0,0.55);
          border-radius: 2px;
          overflow: hidden;
          box-shadow:
            inset 0 1px 1px rgba(0,0,0,0.8),
            0 1px 0 rgba(255,220,160,0.08);
        }

        #progress_fill {
          height: 100%;
          background: linear-gradient(90deg, #8b7335 0%, #c9a961 50%, #f4e4b8 100%);
          border-radius: 2px;
          box-shadow: 0 0 4px rgba(201,169,97,0.7);
        }

        #times {
          display: flex;
          justify-content: space-between;
          margin-top: 6px;
          font-family: "Courier New", monospace;
          font-size: 11px;
          color: #c9a961;
          letter-spacing: 1px;
        }

        @keyframes spin {
          to { transform: rotate(360deg); }
        }

      div(id="player" class = "" + paused + "")
        div(id="plinth")
          div(id="platter_mat")
            div(id="vinyl")
              div(id="label")
                div(id="album_art" style = "background-image: url(" + image_link + ");")
              div(id="spindle")
          div(id="tonearm_arm")
            div(id="counterweight")
            div(id="headshell")
              div(id="cartridge")
          div(id="tonearm_pivot")
          div(id="info")
            div(id="title_wrap" class = "" + title_marquee + "")
              h2(id="song_name") #{title}
            div(id="artist_wrap" class = "" + artist_marquee + "")
              h3(id="artist_name") #{artist}
          div(id="progress_wrap")
            div(id="progress_base")
              div(id="progress_fill" style = "width: " + progress_percentage + "%;")
            div(id="times")
              span(id="time_current") #{progress_time}
              span(id="time_total") #{duration_time}
